# Public (use full URL with https:// — host-only values are normalized at runtime)
NEXT_PUBLIC_SITE_URL=https://nestino-main.vercel.app
NEXT_PUBLIC_VILLA_BASE_DOMAIN=nestino.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional override; default on site is +905346191692
NEXT_PUBLIC_WHATSAPP_E164=

# Curina landing (mounted under /Curina via rewrite from this app)
# Example: https://curina-landing-web.vercel.app
CURINA_ORIGIN=

# Optional: comma-separated top-level path prefixes that belong to Curina when
# Curina emits links like /journal instead of /Curina/journal (public files too).
# Example: /journal,/philosophy,/editorial
CURINA_PATH_PREFIXES=

# Server-only
DATABASE_URL=postgresql://user:pass@host:5432/db
RESEND_API_KEY=
RESEND_FROM_EMAIL=Nestino <onboarding@resend.dev>
INTERNAL_NOTIFY_EMAIL=hello@nestino.ai
CRM_WEBHOOK_URL=
ENGINE_INTERNAL_URL=
ENGINE_INTERNAL_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
